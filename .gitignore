# ========================================
# NestJS / Node.js Project .gitignore
# ========================================

# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
out/

# Environment files (NEVER commit secrets)
.env
.env.*
!.env.example

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage & Testing
coverage/
.nyc_output/
*.lcov

# TypeScript cache
*.tsbuildinfo

# Optional npm cache
.npm/

# Optional eslint cache
.eslintcache

# Prisma
prisma/*.db
prisma/*.db-journal

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# IDE - JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# IDE - Vim
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Docker (local overrides)
docker-compose.override.yml

# Serverless
.serverless/

# Debug
.debug/

# Local development
.local/
knowstack.config.ts
knowstack.config.json

# npm auth tokens
.npmrc
