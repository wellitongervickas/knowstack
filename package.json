{
  "name": "knowstack",
  "version": "1.0.0",
  "description": "Multi-tenant developer documentation platform API",
  "repository": {
    "type": "git",
    "url": "https://github.com/wellitongervickas/knowstack.git"
  },
  "homepage": "https://github.com/wellitongervickas/knowstack#readme",
  "bugs": {
    "url": "https://github.com/wellitongervickas/knowstack/issues"
  },
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "sdk:build": "pnpm --filter @knowstack/sdk build",
    "sdk:release": "pnpm --filter @knowstack/sdk release"
  },
  "keywords": [
    "nestjs",
    "api",
    "documentation",
    "mcp"
  ],
  "author": "KnowStack Contributors",
  "license": "MIT",
  "packageManager": "pnpm@10.19.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "@nestjs/core",
      "prisma",
      "@prisma/client",
      "@prisma/engines",
      "esbuild"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.22.0",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dotenv": "^17.3.1",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.3",
    "nestjs-cls": "^6.2.0",
    "openai": "^6.22.0",
    "picomatch": "^4.0.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@clack/prompts": "^1.0.1",
    "@eslint/js": "^9.39.3",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/testing": "^11.1.14",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.0",
    "@types/picomatch": "^4.0.2",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  }
}
