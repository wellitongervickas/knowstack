{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/scripts/block-relative-imports.js",
            "statusMessage": "Checking imports..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/validate.sh",
            "timeout": 300,
            "statusMessage": "Running validation suite..."
          }
        ]
      }
    ]
  }
}
