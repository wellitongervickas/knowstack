# Application
NODE_ENV=development
PORT=3000
TRUST_PROXY=false                 # Enable only when behind trusted reverse proxy (nginx, ALB, etc.)

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/knowstack

# AI Providers
AI_DEFAULT_PROVIDER=stub          # Options: openai, stub
OPENAI_API_KEY=                   # Required when AI_DEFAULT_PROVIDER=openai
OPENAI_MODEL=gpt-4.1-mini         # Recommended for docs (beats gpt-4o, 83% cheaper)
AI_MAX_RESPONSE_TOKENS=4096       # Max tokens for AI response (gpt-4.1-mini max: 16384)

# Redis Cache
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL_SECONDS=3600      # Cache TTL in seconds (default: 1 hour)
REDIS_CACHE_ENABLED=true          # Toggle caching on/off

# Embedding & Semantic Search
EMBEDDING_ENABLED=true                  # Enable/disable embedding feature
EMBEDDING_DEFAULT_PROVIDER=openai       # Options: openai, stub (use openai for production)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small  # OpenAI embedding model
EMBEDDING_TOP_K=10                      # Number of top documents to retrieve
EMBEDDING_HYBRID_WEIGHT=0.7             # Semantic vs keyword weight (0-1, 0.7 = 70% semantic)
EMBEDDING_RATE_LIMIT_PER_MINUTE=60      # Rate limit for embedding operations
EMBEDDING_MAX_BATCH_SIZE=100            # Max batch size for backfill

# Audit Logging
AUDIT_LOG_ENABLED=false                 # Enable/disable audit logging (default: false)
AUDIT_LOG_RETENTION_DAYS=365            # How long to keep audit logs (default: 365 days)
AUDIT_LOG_CLEANUP_INTERVAL_MS=86400000  # Cleanup interval in milliseconds (default: 24 hours)
AUDIT_LOG_BATCH_DELETE_SIZE=1000        # Batch size for cleanup operations

# Application Base URL
APP_BASE_URL=http://localhost:3000
